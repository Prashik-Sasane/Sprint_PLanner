-- 1. Create the Database
CREATE DATABASE IF NOT EXISTS smart_planner;
USE smart_planner;

-- 2. Create Developers Table (The "Who")
CREATE TABLE developers (
    dev_id INT PRIMARY KEY,
    name VARCHAR(100),
    experience_level VARCHAR(20), -- Senior, Mid, Junior
    primary_skill VARCHAR(50)
);

-- 3. Create Sprint Context Table (The "When")
CREATE TABLE sprint_context (
    sprint_id INT PRIMARY KEY,
    team_load_percentage INT,     -- e.g., 100, 110, 80
    is_holiday_season BOOLEAN     -- 1 for Yes, 0 for No
);

-- 4. Create Historical Tasks Table (The "What")
-- This table 'links' the others using Foreign Keys
CREATE TABLE historical_tasks (
    task_id INT PRIMARY KEY,
    dev_id INT,
    sprint_id INT,
    category VARCHAR(50),
    story_points INT,
    actual_hours FLOAT,
    -- These keys ensure you can't have a task without a real developer
    FOREIGN KEY (dev_id) REFERENCES developers(dev_id),
    FOREIGN KEY (sprint_id) REFERENCES sprint_context(sprint_id)
);